{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Torder",
  "version": "2.1.0",
  "identifier": "com.zhaxideler.torder",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Torder（今序）",
        "width": 1440,
        "height": 900,
        "minWidth": 360,
        "minHeight": 460,
        "decorations": false,
        "resizable": true,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": [
      "WebView2Loader.dll"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
